# ---------------------------------------------------------
# 🌐 Server Configuration
# ---------------------------------------------------------
NODE_ENV=development
PORT=5000
URL=http://localhost:5000

# ---------------------------------------------------------
# 🗄️ Database Configuration
# ---------------------------------------------------------
DATABASE_URL=mongodb://localhost:27017/zaaz

# ---------------------------------------------------------
# 🔐 Security Configuration
# ---------------------------------------------------------
BCRYPT_SALT_ROUNDS=10
SESSION_SECRET=your_session_secret_here
SERVER_API_KEY=your_server_api_key_here
DEFAULT_PASSWORD=your_default_password_here

# ---------------------------------------------------------
# 🪪 JWT Configuration
# ---------------------------------------------------------

# 🔑 Access Token
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_SECRET_EXPIRES_IN=1d

# 🔄 Refresh Token
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_SECRET_EXPIRES_IN=15d

# 🔁 Reset Password Token
JWT_RESET_PASSWORD_SECRET=your_jwt_reset_password_secret_here
JWT_RESET_PASSWORD_SECRET_EXPIRES_IN=10m

# 📧 Email Verification Token
JWT_EMAIL_VERIFICATION_SECRET=your_jwt_email_verification_secret_here
JWT_EMAIL_VERIFICATION_SECRET_EXPIRES_IN=30m

# ---------------------------------------------------------
# ⚙️ Cluster Configuration
# ---------------------------------------------------------
CLUSTER_ENABLED=false

# ---------------------------------------------------------
# ⚡ Redis Configuration
# ---------------------------------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------
# 🐇 RabbitMQ Configuration
# ---------------------------------------------------------
RABBITMQ_ENABLED=false
RABBITMQ_URL=

# ---------------------------------------------------------
# 📨 Kafka Configuration
# ---------------------------------------------------------
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=zaaz-server

# ---------------------------------------------------------
# 🌍 CORS Configuration
# ---------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------
# 🌍 Frontend Configuration
# ---------------------------------------------------------
ADMINPANEL_URL=http://localhost:3000
WEBSITE_URL=http://localhost:5173

# ---------------------------------------------------------
# 🔗 UI Links Configuration
# ---------------------------------------------------------
RESET_PASSWORD_UI_LINK=http://localhost:3000/reset-password
EMAIL_VERIFICATION_UI_LINK=http://localhost:3000/verify-email

# ---------------------------------------------------------
# 📧 Email Configuration
# ---------------------------------------------------------
EMAIL=example@gmail.com
EMAIL_PROVIDER=smtp             # smtp | resend | sendgrid

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_EMAIL=example@gmail.com
SMTP_EMAIL_PASSWORD=your_email_app_password_here

# Resend Configuration
RESEND_EMAIL=
RESEND_API_KEY=

# SendGrid Configuration
SENDGRID_EMAIL=
SENDGRID_API_KEY=

# ---------------------------------------------------------
# 💳 Credits & Token Pricing Configuration
# ---------------------------------------------------------
DEFAULT_CREDIT_PRICE=0.00001
DEFAULT_INPUT_TOKEN_PRICE=0.0000003
DEFAULT_OUTPUT_TOKEN_PRICE=0.0000025

# ---------------------------------------------------------
# 🔐 Google OAuth Configuration
# ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------
# ☁️ Google Cloud Configuration
# ---------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcs-credentials.json
GOOGLE_CLOUD_STORAGE_BUCKET=your_bucket_name_here
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here

# ---------------------------------------------------------
# 💳 Stripe Payment Configuration
# ---------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=

# Stripe Test Configuration
STRIPE_PUBLIC_KEY_TEST=
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_KEY_TEST=

# ---------------------------------------------------------
# 💰 bKash Payment Configuration
# ---------------------------------------------------------
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_BASE_URL=

# bKash Test Configuration
BKASH_USERNAME_TEST=
BKASH_PASSWORD_TEST=
BKASH_APP_KEY_TEST=
BKASH_APP_SECRET_TEST=
BKASH_BASE_URL_TEST=

# ---------------------------------------------------------
# 🏦 SSLCommerz Payment Configuration
# ---------------------------------------------------------
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_BASE_URL=

# SSLCommerz Test Configuration
SSLCOMMERZ_STORE_ID_TEST=
SSLCOMMERZ_STORE_PASSWORD_TEST=
SSLCOMMERZ_BASE_URL_TEST=
